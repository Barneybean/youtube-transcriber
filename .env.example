# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="file:./dev.db"

# Optional: Override default port (19720)
# PORT=19720

# Optional: Where channel exports are written
# (default: ./transcript/<Channel Name>/ inside the repo)
# YTT_EXPORT_ROOT="/path/to/your/transcript/library"

# Optional: Full-video MP4 download (the "MP4 + transcript" action).
# Videos are saved to <export root>/<Channel Name>/video/.
# VIDEO_DOWNLOAD_FORMAT="bv*+ba/b"      # yt-dlp format selector (default: best video+audio)
# VIDEO_DOWNLOAD_TIMEOUT_MS="900000"    # download timeout (default: 15 min)

# Whisper configuration (adjust paths to match your setup)
WHISPER_CLI="/path/to/your/.venv/bin/whisper"
WHISPER_PYTHON_BIN="/path/to/your/.venv/bin/python3"

# Optional: Force specific backend (auto, mlx, or openai)
# WHISPER_BACKEND="auto"

# Optional: Force specific device for OpenAI Whisper (auto, cpu, or mps)
# WHISPER_DEVICE="auto"
# Optional: Local Whisper model (default large-v3-turbo; "base" is faster but low accuracy)
# WHISPER_MODEL="large-v3-turbo"

# Optional: Transcription timeout in milliseconds (default: 480000)
# WHISPER_TIMEOUT_MS="480000"

# Optional: Repetition-collapse repair. When Whisper degenerates into loops on
# music-heavy passages, the affected windows are re-transcribed with a stronger
# model (loop-resistant decoding). On by default; requires ffmpeg.
# WHISPER_REPAIR_ENABLED="true"
# WHISPER_REPAIR_MODEL="large-v3"
# FFMPEG_PATH="ffmpeg"

# Optional: Cloud Whisper API (BYOK — set API key to enable cloud transcription fallback)
# Cloud Whisper sits between YouTube captions and local Whisper in the fallback chain.
# Supported providers: groq (default), openai
# WHISPER_CLOUD_PROVIDER="groq"
# WHISPER_CLOUD_API_KEY="gsk_..."
# WHISPER_CLOUD_MODEL="whisper-large-v3-turbo"

# Optional: AI proofreading of transcripts (BYOK — Anthropic Claude)
# After transcription, fixes ASR errors (homophones, garbled terms) without
# rephrasing. Enabled automatically when a credential is set; fails open.
# ANTHROPIC_API_KEY="sk-ant-..."
# PROOFREAD_BACKEND="claude-cli"    # route through the local Claude Code CLI
#                                   # (claude -p) instead of the API — no key
#                                   # needed; setting it enables the feature
# CLAUDE_CLI_PATH="claude"          # CLI binary path for the claude-cli backend
# PROOFREAD_ENABLED="true"          # "false" to force-disable
# PROOFREAD_MODEL="claude-opus-4-8"
# PROOFREAD_SOURCES="whisper"       # "whisper" (default) or "all" (also captions)

# Optional: HuggingFace token for speaker diarization (pyannote.audio)
# Get yours at https://huggingface.co/settings/tokens
# You must also accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# HF_TOKEN="hf_..."

# Spotify (optional — enables Spotify podcast transcription)
# SPOTIFY_CLIENT_ID=       # From developer.spotify.com/dashboard
# SPOTIFY_CLIENT_SECRET=   # From developer.spotify.com/dashboard
# SPOTIFY_ACCESS_TOKEN=    # Easiest: grab from browser console on open.spotify.com (expires ~1hr)
#                          # Run: fetch('/get_access_token?reason=transport&productType=web-player').then(r=>r.json()).then(d=>console.log(d.accessToken))
# SPOTIFY_SP_DC=           # Alternative: your sp_dc cookie (automated but may be CDN-blocked)
